# =============================================================================
# Root .env — used when running dev from repo root: bun run dev
# Copy to .env and fill in values. Env is loaded by Bun and passed to all
# Turbo tasks (Next.js, PartyKit, plugin build), so every package sees them.
# When running a single package (e.g. bun run dev:mcp), use the root .env too.
# =============================================================================

# -----------------------------------------------------------------------------
# MCP Server (Next.js) — packages/mcp-server
# -----------------------------------------------------------------------------
PARTYKIT_HOST=localhost:1999 # or your production host: your-remote-host.partykit.dev
BRIDGE_SECRET=your-secret-here

# -----------------------------------------------------------------------------
# PartyKit (WebSocket + Registry) — packages/websocket
# -----------------------------------------------------------------------------
# BRIDGE_SECRET — same as above; must match MCP server and PartyKit.
# For local dev, PartyKit also reads .env from packages/websocket if you run
# partykit dev from that directory; when using `bun run dev` from root, env
# is inherited from this file.

# -----------------------------------------------------------------------------
# Plugin (build-time only) — packages/plugin
# -----------------------------------------------------------------------------
MCP_LOCAL_URL=http://localhost:3000/mcp
MCP_REMOTE_URL=https://your-mcp.example.com/mcp
WEBSOCKET_LOCAL_URL=http://localhost:1999
WEBSOCKET_REMOTE_URL=https://your-websocket.example.com/party/websocket
USER_HASH_SALT=figma-mcp-bridge-v1
