# =============================================================================
# Root .env — used when running dev from repo root: bun run dev
# Copy to .env and fill in values. Env is loaded by Bun and passed to all
# Turbo tasks (Next.js, mcp server, plugin build), so every package sees them.
# When running a single package (e.g. bun run dev:mcp), use the root .env too.
# =============================================================================

# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------
WEBSOCKET_PORT=8765

# -----------------------------------------------------------------------------
# Plugin (build-time only) — packages/plugin
# -----------------------------------------------------------------------------
# WEBSOCKET_PORT=8765
