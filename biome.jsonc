{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/remix",
    "ultracite/biome/next"
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "useSortedProperties": "off",
        "useSortedKeys": "off",
        "useSortedInterfaceMembers": "off"
      }
    }
  },
  "linter": {
    "rules": {
      "nursery": {
        "useSortedClasses": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/plugin/backend/**"],
      "javascript": {
        "globals": [
          "figma",
          "__html__",
          "__MCP_LOCAL_URL__",
          "__MCP_REMOTE_URL__",
          "__WEBSOCKET_LOCAL_URL__",
          "__WEBSOCKET_REMOTE_URL__",
          "__USER_HASH_SALT__"
        ]
      }
    },
    {
      "includes": ["packages/plugin/frontend/**"],
      "javascript": {
        "globals": [
          "__MCP_LOCAL_URL__",
          "__MCP_REMOTE_URL__",
          "__PLUGIN_VERSION__",
          "__WEBSOCKET_LOCAL_URL__",
          "__WEBSOCKET_REMOTE_URL__"
        ]
      }
    }
  ]
}
